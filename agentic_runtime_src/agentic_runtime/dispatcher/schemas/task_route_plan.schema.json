{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgenticOS Task Route Plan",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "route_plan_id",
    "created_at",
    "user_text",
    "planner_mode",
    "intent",
    "selected_app_id",
    "route_reason",
    "risk_class",
    "requires_robot_motion",
    "needs_confirmation",
    "target",
    "app_task_input",
    "preflight_checks",
    "fallback",
    "user_summary"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "task_id": {"type": "string", "minLength": 1},
    "route_plan_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "user_text": {"type": "string"},
    "planner_mode": {"type": "string", "enum": ["llm", "rule_based"]},
    "intent": {
      "type": "string",
      "enum": [
        "capture_photo",
        "multi_angle_photo",
        "recent_photos",
        "robot_status",
        "robot_stop",
        "tasks",
        "last_task",
        "help",
        "unsupported"
      ]
    },
    "selected_app_id": {
      "type": "string",
      "enum": [
        "robot_photographer_agent",
        "builtin.status",
        "builtin.stop",
        "builtin.tasks",
        "builtin.last_task",
        "builtin.help",
        "unsupported"
      ]
    },
    "route_reason": {"type": "string"},
    "risk_class": {"type": "string", "enum": ["read_only", "named_motion", "emergency_control", "unsupported"]},
    "requires_robot_motion": {"type": "boolean"},
    "needs_confirmation": {"type": "boolean"},
    "target": {"type": "string", "enum": ["workspace"]},
    "app_task_input": {"type": "object"},
    "preflight_checks": {"type": "array", "items": {"type": "object"}},
    "fallback": {
      "type": "object",
      "required": ["used", "reason"],
      "properties": {
        "used": {"type": "boolean"},
        "reason": {"type": "string"}
      },
      "additionalProperties": true
    },
    "user_summary": {"type": "string"}
  },
  "additionalProperties": false
}
