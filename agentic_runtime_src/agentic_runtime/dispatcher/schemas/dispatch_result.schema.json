{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgenticOS Dispatch Result",
  "type": "object",
  "required": ["success", "status", "task_id", "route_plan_id", "selected_app_id"],
  "properties": {
    "success": {"type": "boolean"},
    "status": {"type": "string"},
    "task_id": {"type": "string"},
    "route_plan_id": {"type": "string"},
    "dispatcher_session_id": {"type": "string"},
    "selected_app_id": {"type": "string"},
    "selected_agents": {"type": "array"},
    "risk_class": {"type": "string"},
    "requires_robot_motion": {"type": "boolean"},
    "needs_confirmation": {"type": "boolean"},
    "route_plan": {"type": "object"},
    "app_result": {"type": "object"},
    "result_summary": {"type": "object"},
    "task_log_path": {"type": "string"},
    "error_code": {"type": "string"},
    "message": {"type": "string"}
  },
  "additionalProperties": true
}
