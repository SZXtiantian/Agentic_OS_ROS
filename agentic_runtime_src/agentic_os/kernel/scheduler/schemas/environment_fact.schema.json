{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "environment_fact.schema.json",
  "type": "object",
  "required": [
    "fact_id",
    "key",
    "value",
    "source_node_id",
    "source_capability",
    "source_syscall_id",
    "source_audit_id",
    "source_result_hash",
    "timestamp_ns",
    "ttl_ns",
    "confidence",
    "world_epoch",
    "schema_id",
    "real_dependency"
  ],
  "properties": {
    "fact_id": { "type": "string" },
    "key": { "type": "string" },
    "value": {},
    "source_node_id": { "type": "string", "minLength": 1 },
    "source_capability": { "type": "string", "minLength": 1 },
    "source_syscall_id": { "type": "string", "minLength": 1 },
    "source_audit_id": { "type": "string", "minLength": 1 },
    "source_result_hash": { "type": "string", "minLength": 1 },
    "timestamp_ns": { "type": "integer" },
    "ttl_ns": { "type": "integer", "minimum": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "world_epoch": { "type": "integer" },
    "schema_id": { "type": "string" },
    "real_dependency": { "type": "string", "minLength": 1 },
    "metadata": { "type": "object" }
  },
  "additionalProperties": true
}
