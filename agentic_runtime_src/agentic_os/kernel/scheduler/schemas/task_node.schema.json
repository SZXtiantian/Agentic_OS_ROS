{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task_node.schema.json",
  "type": "object",
  "required": [
    "node_id",
    "task_graph_id",
    "user_goal_id",
    "agent_id",
    "app_id",
    "session_id",
    "capability",
    "operation_type",
    "query_type",
    "status"
  ],
  "properties": {
    "node_id": { "type": "string", "minLength": 1 },
    "task_graph_id": { "type": "string", "minLength": 1 },
    "user_goal_id": { "type": "string" },
    "original_goal_id": { "type": "string" },
    "agent_id": { "type": "string" },
    "agent_name": { "type": "string" },
    "app_id": { "type": "string" },
    "session_id": { "type": "string" },
    "capability": { "type": "string" },
    "operation_type": { "type": "string" },
    "query_type": {
      "type": "string",
      "enum": ["llm", "skill", "robot_capability", "tool", "memory", "storage", "context", "human"]
    },
    "params": { "type": "object" },
    "metadata": { "type": "object" },
    "status": {
      "type": "string",
      "enum": [
        "created",
        "admitted",
        "waiting",
        "ready",
        "leased",
        "dispatching",
        "running",
        "completed",
        "failed",
        "blocked",
        "suspended",
        "cancelled",
        "stale",
        "rejected"
      ]
    },
    "safety_class": { "type": "string" },
    "lane": { "type": "string" },
    "base_priority": { "type": "integer" },
    "inherited_priority": { "type": "integer" },
    "effective_priority": { "type": "integer" },
    "created_ns": { "type": "integer" },
    "ready_since_ns": { "type": ["integer", "null"] },
    "started_ns": { "type": ["integer", "null"] },
    "finished_ns": { "type": ["integer", "null"] },
    "deadline_ns": { "type": ["integer", "null"] },
    "runtime_budget_ns": { "type": ["integer", "null"] },
    "estimated_runtime_ns": { "type": ["integer", "null"] },
    "period_ns": { "type": ["integer", "null"] },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "dependents": { "type": "array", "items": { "type": "string" } },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["resource_id"],
        "properties": {
          "resource_id": { "type": "string", "minLength": 1 },
          "mode": { "type": "string", "enum": ["exclusive", "shared"] },
          "amount": { "type": "integer", "minimum": 1 },
          "lease_ttl_ns": { "type": "integer", "minimum": 1 },
          "priority_ceiling": { "type": "integer", "minimum": 0 },
          "preemptible": { "type": "boolean" },
          "reason": { "type": "string" },
          "agent_resource_type": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "preconditions": { "type": "array", "items": { "type": "object" } },
    "required_permissions": { "type": "array", "items": { "type": "string" } },
    "safety_constraints": { "type": "object" },
    "input_schema_id": { "type": "string" },
    "output_schema_id": { "type": "string" },
    "route_segment_id": { "type": ["string", "null"] },
    "workspace_zone": { "type": ["string", "null"] },
    "produces_facts": { "type": "array", "items": { "type": "string" } },
    "consumes_facts": { "type": "array", "items": { "type": "string" } },
    "reusable_output": { "type": "boolean" },
    "opportunistic": { "type": "boolean" },
    "fusion_group_id": { "type": ["string", "null"] },
    "preempt_policy": { "type": "string" },
    "syscall_id": { "type": "string" },
    "syscall_target": { "type": "string" },
    "syscall_queue_name": { "type": "string" },
    "resource_lease_ids": { "type": "array", "items": { "type": "string" } },
    "result": { "type": ["object", "null"] },
    "error_code": { "type": "string" },
    "audit_ids": { "type": "array", "items": { "type": "string" } },
    "critical_path_rank": { "type": "integer" }
  },
  "additionalProperties": true
}
