<?xml version="1.0" encoding="utf-8"?>
<robot name="car" xmlns:xacro="http://ros.org/wiki/xacro">
    <xacro:arg name="prefix" default="" />
    <xacro:property name="lidar"        value="$(env LIDAR_TYPE)"/>
    <xacro:property name="machine"      value="$(env MACHINE_TYPE)"/>
    <xacro:if value="${machine !=  'ROSOrin_Mecanum_Pro'}">
        <xacro:if value="${machine == 'ROSOrin_Mecanum'}">
            <xacro:include filename="$(find rosorin_description)/urdf/mecanum.xacro"/>
        </xacro:if>
        <xacro:if value="${machine == 'ROSOrin_Acker'}">
            <xacro:include filename="$(find rosorin_description)/urdf/acker.xacro"/>
        </xacro:if>
        <xacro:if value="${machine ==  'ROSOrin_Differential'}">
            <xacro:include filename="$(find rosorin_description)/urdf/differential.xacro"/>
        </xacro:if>

        <xacro:if value="${lidar == 'MS200'}">
            <xacro:include filename="$(find rosorin_description)/urdf/pro/lidar_ms200.urdf.xacro"/>
        </xacro:if>

        <xacro:if value="${lidar == 'LD19'}">
            <xacro:include filename="$(find rosorin_description)/urdf/pro/lidar_ld19.urdf.xacro"/>
        </xacro:if>

        <xacro:if value="${lidar == 'SCLIDAR'}">
            <xacro:include filename="$(find rosorin_description)/urdf/pro/lidar.urdf.xacro"/>
        </xacro:if>
    </xacro:if>


    <xacro:include filename="$(find rosorin_description)/urdf/materials.xacro" />
    <xacro:if value="${machine ==  'ROSOrin_Mecanum_Pro'}">
        <xacro:include filename="$(find rosorin_description)/urdf/pro/rosorinpro.xacro"/>
    </xacro:if>
</robot>